from collections import defaultdict

class Solution:
    def countVowelSubstrings(self, word: str) -> int:
        vowels = set("aeiou")
        n = len(word)
        count = 0
        
        for i in range(n):
            if word[i] not in vowels:
                continue
            
            seen = defaultdict(int)
            for j in range(i, n):
                if word[j] not in vowels:
                    break
                seen[word[j]] += 1
                if len(seen) == 5:
                    count += 1
                    
        return count
